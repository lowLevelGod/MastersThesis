@Article{compare-pead-analysts-vs-time-series,
journal={Journal of Accounting Research},
author={Joshua Livnat and Richard R. Mendenhall},
title={Comparing the Post Earnings Announcement Drift for Surprises Calculated from Analyst and Time Series Forecasts},
year={2006},
month={March},
pages={177-205},
volume={44},
number={1},
abstract={Post earnings announcement drift is the tendency for a stock's cumulative abnormal returns to drift in the direction of an earnings surprise for several weeks following an earnings announcement. We show that the drift is significantly larger when defining the earnings surprise using analysts' forecasts and actual earnings from I/B/E/S than when using a time series model based on Compustat earnings data. Neither Compustat's policy of restating earnings nor the inclusion of â€œspecial itemsâ€ in reported earnings contribute significantly to the disparity in drift magnitudes. Rather, our results suggest that this disparity is attributable to differences between analyst forecasts and those of timeâ€series modelsâ€”or at least to factors correlated with these differences. Further, we document that analyst forecasts lead to return patterns around future earnings announcements that differ from those observed when using timeâ€series models, suggesting that the two types of surprises may capture somewhat different forms of mispricing.},
keywords={},
doi={10.1111/j.1475-679X.2006.00196.x},
url={https://ideas.repec.org/a/bla/joares/v44y2006i1p177-205.html},
}

